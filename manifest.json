{
  "id": "com.vkmeow.messenger.pwa",
  "name": "VK Meow Messenger Pro",
  "short_name": "VK Meow",
  "description": "Безопасный мессенджер нового поколения с E2EE шифрованием, голосовыми, видео и полной PWA-поддержкой.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "standalone",
    "fullscreen",
    "minimal-ui"
  ],
  "orientation": "portrait-primary",
  "theme_color": "#000000",
  "background_color": "#000000",
  "lang": "ru",
  "dir": "ltr",
  "categories": [
    "social",
    "communication",
    "security"
  ],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshot-narrow.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Главный экран VK Meow на мобильном устройстве"
    },
    {
      "src": "screenshot-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Экран переписки VK Meow на планшете/десктопе"
    }
  ],
  "shortcuts": [
    {
      "name": "Избранное",
      "short_name": "Избранное",
      "description": "Быстрый доступ к сохранённым сообщениям",
      "url": "./?action=cloud",
      "icons": [
        {
          "src": "icon-192-maskable.png",
          "sizes": "192x192",
          "purpose": "maskable"
        }
      ]
    },
    {
      "name": "Контакты",
      "short_name": "Контакты",
      "description": "Открыть список контактов",
      "url": "./?tab=contacts",
      "icons": [
        {
          "src": "icon-192-maskable.png",
          "sizes": "192x192",
          "purpose": "maskable"
        }
      ]
    },
    {
      "name": "Настройки",
      "short_name": "Настройки",
      "description": "Открыть настройки приватности",
      "url": "./?tab=settings",
      "icons": [
        {
          "src": "icon-192-maskable.png",
          "sizes": "192x192",
          "purpose": "maskable"
        }
      ]
    }
  ],
  "share_target": {
    "action": "./",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": [
            "image/*",
            "video/*"
          ]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+meow",
      "url": "./?uri=%s"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.vkmeow.messenger",
      "id": "com.vkmeow.messenger"
    }
  ],
  "prefer_related_applications": false,
  "iarc_rating_id": ""
}